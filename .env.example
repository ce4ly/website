# Copiar a .env y rellenar. Documentación Mailgun:
# https://documentation.mailgun.com/

# Clave privada de la API (región US o EU según tu cuenta)
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dominio de envío verificado en Mailgun (ej. mg.ce4ly.cl o sandbox)
MAILGUN_DOMAIN=mg.ce4ly.cl

# Región de la cuenta: us (por defecto) o eu
MAILGUN_REGION=eu

# Dirección verificada como remitente (debe pertenecer al dominio anterior)
MAILGUN_FROM=Radio Club Lircay <noreply@mg.ce4ly.cl>

# Bandeja de entrada del club (opcional; por defecto contacto@ce4ly.cl)
CONTACT_TO=contacto@ce4ly.cl

# Puerto del servidor de producción (opcional; por defecto 4173)
# PORT=4173

# --- Contacto con PHP (Apache/nginx + PHP en el servidor) ---
# Tras `vite build`, existe dist/api/contact.php. Copia también:
#   public/api/mailgun.local.php   (desde public/api/mailgun.local.example.php)
# y desactiva el endpoint Node si solo usas PHP. Variables MAILGUN_* arriba
# sirven para Vite (dev) y npm start; el script PHP usa mailgun.local.php.
